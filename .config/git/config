[user]
    name = João Sampaio
    email = jpmelos@gmail.com

[core]
    editor = nvim
    pager = sh ~/devel/dotfiles/references/scripts/git-pager.sh

[interactive]
    diffFilter = delta --color-only

[delta]
    navigate = true
    line-numbers = true

[init]
    defaultBranch = main
    templateDir = /Users/jpmelos/devel/git-template

[branch]
    sort = -committerdate

[fetch]
    prune = true

[log]
    date = local

[status]
    showUntrackedFiles = all

[diff]
    colorMoved = no

[merge]
    conflictStyle = diff3

[rebase]
    updateRefs = true
    rescheduleFailedExec = true

[rerere]
    enabled = true

[commit]
    verbose = true
    gpgSign = true

[tag]
    gpgSign = true

[push]
    default = simple
    autoSetupRemote = true

[pull]
    rebase = true

[color "branch"]
    current = green dim bold
    remote = red dim

[color "status"]
    added = green dim
    changed = blue dim
    untracked = red dim

[color "diff"]
    meta = black bold
    frag = black
    new = green dim bold
    old = red dim bold
    whitespace = black red dim bold

[alias]
    main-branch = ! ~/devel/dotfiles/references/scripts/check-for-git-remote-head.sh && git symbolic-ref refs/remotes/origin/HEAD | cut -d'/' -f4
    main-branch-remote = ! git rev-parse --abbrev-ref $(git main-branch)@{upstream}
    root = rev-parse --show-toplevel
    nuke = "! f() { source "$HOME/devel/dotfiles/references/scripts/gitfunctions.sh"; __git_nuke; }; f"
    big-revert = "! f() { source "$HOME/devel/dotfiles/references/scripts/gitfunctions.sh"; __git_big_revert; }; f"

    # List of shorthands:
    # a = add
    # b = branch
    # c = commit
    # d = diff
    # e =
    # f = fetch
    # g =
    # h = reserved for `gh` (GitHub's CLI tool)
    # i =
    # j =
    # k =
    # l = log
    # m = merge
    # n =
    # o = checkout
    # p = pl=pull ps=push
    # q =
    # r = rb=rebase rs=reset
    # s = sh=show st=status
    # t = ls-tree
    # u =
    # v =
    # w =
    # x =
    # y = cherry-pick
    # z =

    # a = add
    a = add
    an = add -N
    aa = add -A :/
    apa = add --patch

    # b = branch
    b = branch
    bc = branch --show-current
    br = "! f() { git branch -vv --color=always | head -n 20; }; f"
    bn = checkout -b  # n = new
    bd = branch -D  # d = delete
    bdd = "! f() { git branch | grep -v '^*' | xargs git branch -D; }; f"

    # c = commit
    c = commit
    ca = commit -a
    cm = commit --amend
    cn = commit -n
    cam = commit -a --amend
    can = commit -a -n
    cmn = commit --amend -n
    camn = commit -a --amend -n
    cw = commit --no-gpg-sign -a -n -m "WIP"

    # d = diff
    d = diff
    df = diff --stat
    dc = diff --cached
    dcf = diff --cached --stat
    dm = ! git diff $(git main-branch)...HEAD
    dmf = ! git diff $(git main-branch)...HEAD --stat
    dom = ! git diff $(git main-branch-remote)...HEAD
    domf = ! git diff $(git main-branch-remote)...HEAD --stat

    # f = fetch
    f = fetch --all

    # l = log
    l = "! f() { git log --color=always --oneline --graph --decorate $@ | awk -f ~/devel/dotfiles/references/scripts/git-log-prepend-number-awk.sh | less -R; }; f"
    ll = "! f() { git log --date=format:'%a %Y-%m-%d %H:%M:%S' --pretty=tformat:'%h|%an|%ad|%<(60,trunc)%s' | column -t -s '|'; }; f"
    lp = log -p --pretty=fuller --stat

    # m = merge
    m = merge
    mm = ! git merge $(git main-branch)
    mom = ! git merge $(git main-branch-remote)
    mc = merge --continue
    ma = merge --abort

    # o = checkout
    o = checkout
    om = ! git checkout $(git main-branch)
    of = checkout -f

    # pl = pull
    pl = pull

    # ps = push
    ps = push
    psf = push --force-with-lease

    # rb = rebase
    rb = rebase
    rbm = ! git rebase $(git main-branch)
    rbom = ! git rebase $(git main-branch-remote)
    rbi = rebase -i
    rbim = ! git rebase -i $(git main-branch)
    rbiom = ! git rebase -i $(git main-branch-remote)
    rbc = rebase --continue
    rba = rebase --abort

    # rs = reset
    rs = reset
    rsu = reset HEAD~1
    rso = reset --hard @{upstream}
    rsm = ! git reset --hard $(git main-branch)
    rsom = ! git reset --hard $(git main-branch-remote)

    # sh = show
    sh = "! f() { if [[ \"$1\" =~ ^- ]]; then HEADN=\"${1#-}\"; shift; git show \"HEAD~$HEADN\" $@; else git show \"$@\"; fi; }; f"
    shf = "! f() { if [[ \"$1\" =~ ^- ]]; then HEADN=\"${1#-}\"; shift; git show --stat $@ \"HEAD~$HEADN\"; else git show --stat \"$@\"; fi; }; f"

    # st = status
    st = status

    # t = ls-tree
    t = ls-tree HEAD --

    # w = worktree
    w = worktree
    wa = worktree add
    wl = worktree list
    wp = worktree prune

    # y = cherry-pick
    y = cherry-pick

[include]
    path = ~/devel/dotfiles/references/gitconfigs/gpg-keys

[includeIf "gitdir:~/devel/close/"]
    path = ~/devel/dotfiles/references/gitconfigs/close

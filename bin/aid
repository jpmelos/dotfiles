#!/usr/bin/env bash
set -euo pipefail
trap 'echo "Exit status $? at line $LINENO from: $BASH_COMMAND" >&2' ERR

if [[ $# -eq 0 ]]; then
    echo "Error: Please provide a title for the session" >&2
    exit 1
fi

# If `.git` is a file (worktree), resolve to the main repository directory.
# Otherwise, use the current directory.
if [[ -f .git ]]; then
    # `.git` file contains: `gitdir: /path/to/main/.git/worktrees/<name>`.
    main_git_dir="$(sed 's/^gitdir: //' .git)"
    # Resolve to the main repo's `.git` directory (strip `/worktrees/<name>`).
    main_git_dir="$(realpath "$main_git_dir/../..")"
    # The main repository is the parent of the `.git` directory.
    project_dir="$(dirname "$main_git_dir")"
else
    project_dir="$(pwd)"
fi

devel_dir="$(realpath "$HOME/devel")"
group_name="${project_dir#"$devel_dir"/}"

aoe add --group "$group_name" --title "$*"

#!/usr/bin/env bash
set -euo pipefail
trap 'echo "Exit status $? at line $LINENO from: $BASH_COMMAND" >&2' ERR

#/ Run Claude Code inside a Docker container.
#/
#/ Usage: ai [options] [-- harness-args...]
#/ Options:
#/   --profile <name>  Specify profile for API key lookup (default: auto-detect
#/                     from path, first component after `~/devel`)
#/   --env             Only export environment variables, don't run
#/   --process-output  Capture and process output (requires `--print` and
#/                     `--output-format json` in harness args)
#/   --force-rebuild   Force rebuild of Docker image
#/   --no-build-cache  Build from scratch without using cache
#/   --no-rebuild      Skip rebuilding image even if outdated
#/   --allow-stale     If build fails, use existing image (fatal if none
#/                     exists)
#/   --help            Show this help
#/
#/ Arguments after `--` are passed directly to Claude Code.
#/
#/ Configuration:
#/   Expects 1Password items at:
#/   - `op://Private/AI Agents Configuration/notesPlain` (API keys)
#/   - `op://Private/GH Token/notesPlain` (GitHub token)
#/
#/   API keys format (JSON):
#/   ```
#/   {
#/     "profiles": {
#/       "username": {
#/         "api_key": "sk-..."
#/       },
#/       "orgname": {
#/         "api_key": "sk-...",
#/         "fallback_to_username": bool
#/       }
#/     }
#/   }
#/   ```
#/
#/   If a profile has `"fallback_to_username": true`, missing API keys fall
#/   back to the username profile. Otherwise, no fallback is attempted.

# ============================================================================
# Initial checks and configuration
# ============================================================================

if [ -z "${BASH_VERSION:-}" ]; then
    echo "Error: This script requires bash" >&2
    exit 1
fi

if ! command -v docker &> /dev/null; then
    echo "Error: Docker is not installed" >&2
    exit 1
fi

if ! docker info &> /dev/null; then
    echo "Error: Docker daemon is not running" >&2
    exit 1
fi

if ! command -v bc &> /dev/null; then
    echo "Error: bc is not installed" >&2
    exit 1
fi

if ! command -v jq &> /dev/null; then
    echo "Error: jq is not installed" >&2
    exit 1
fi

if ! command -v realpath &> /dev/null; then
    echo "Error: realpath is not installed" >&2
    exit 1
fi

if ! command -v shuf &> /dev/null; then
    echo "Error: shuf is not installed" >&2
    exit 1
fi

if [[ "${AGENT_ENV_SET:-}" != "true" ]]; then
    if ! command -v op &> /dev/null; then
        echo "Error: 1Password CLI (op) is not installed" >&2
        exit 1
    fi
fi

devel_dir="$(realpath "$HOME/devel")"
if [[ ! -d "$devel_dir" ]]; then
    echo "Error: $HOME/devel does not exist" >&2
    exit 1
fi

current_dir="$(realpath "$(pwd)")"
if [[ "$current_dir/" != "$devel_dir/"* ]]; then
    echo "Error: not inside ~/devel" >&2
    exit 1
fi

if [[ "$current_dir" == "$devel_dir" ]]; then
    echo "Error: Cannot run from ~/devel root, must be in a subdirectory" >&2
    exit 1
fi

project_relative_dir="${current_dir#"$devel_dir"/}"

profile=""
env_only=false
process_output=false
force_rebuild=false
no_build_cache=false
no_rebuild=false
allow_stale=false
show_help=false
harness_print_mode=false
harness_json_output=false
harness_args=()

while [[ $# -gt 0 ]]; do
    case "$1" in
        --profile)
            shift
            if [[ $# -eq 0 ]]; then
                echo "Error: --profile requires an argument" >&2
                exit 1
            fi
            profile="$1"
            shift
            ;;
        --env)
            env_only=true
            shift
            ;;
        --process-output)
            process_output=true
            shift
            ;;
        --force-rebuild)
            force_rebuild=true
            shift
            ;;
        --no-build-cache)
            no_build_cache=true
            shift
            ;;
        --no-rebuild)
            no_rebuild=true
            shift
            ;;
        --allow-stale)
            allow_stale=true
            shift
            ;;
        --help)
            show_help=true
            shift
            ;;
        --)
            shift
            harness_args=("$@")
            break
            ;;
        *)
            echo "Error: Unknown option '$1'" >&2
            exit 1
            ;;
    esac
done

# Detect print mode and JSON output format in harness args.
prev_arg=""
for arg in "${harness_args[@]}"; do
    if [[ "$arg" == "--print" ]]; then
        harness_print_mode=true
    fi
    if [[ "$arg" == "--output-format=json" ]]; then
        harness_json_output=true
    elif [[ "$prev_arg" == "--output-format" && "$arg" == "json" ]]; then
        harness_json_output=true
    fi
    prev_arg="$arg"
done

# Validate that `--process-output` is only used with `--print --output-format
# json`.
if [[ "$process_output" == "true" ]]; then
    if [[ "$harness_print_mode" != "true" ]] \
        || [[ "$harness_json_output" != "true" ]]; then
        echo "Error: \`--process-output\` requires \`--print\` and \`--output-format json\` in harness args" >&2
        exit 1
    fi
fi

if [[ "$show_help" == "true" ]]; then
    grep '^#/' "${BASH_SOURCE[0]}" | cut -c4-
    exit 0
fi

username="$(whoami)"

dockerfile_path="$devel_dir/dotfiles/references/ai_containers/Dockerfile"
docker_image_name="$username-claude:latest"
container_prefix="claude_code"

# ============================================================================
# Helper functions
# ============================================================================

# Transform a link into a hard copy.
dereference() {
    tmp=$(mktemp) || return
    cp -L "$1" "$tmp" && mv "$tmp" "$1"
}

# Process Claude Code output from print mode.
process_print_output() {
    local output="$1"

    local result
    local cost
    local duration_ms
    local duration

    result=$(jq -r '.result // ""' <<< "$output")
    cost=$(jq -r '.total_cost_usd // 0' <<< "$output")
    duration_ms=$(jq -r '.duration_ms // 0' <<< "$output")
    duration=$(printf "%.3f" "$(bc <<< "scale=3; $duration_ms / 1000")")

    echo "$result"
    echo ""
    echo "Cost: \$$(round_up_cents "$cost")"
    echo "Duration: $(format_duration "$duration")"
}

build_image() {
    local use_cache="$1"

    echo "Building Docker image..." >&2

    local build_args=(
        --build-arg UID="$(id -u)"
        --build-arg GID="$(id -g)"
        --build-arg HOME="$HOME"
        --build-arg BUILD_DATE="$(date +%Y-%m-%d)"
        --build-arg CLAUDE_CODE_CHANNEL="stable"
    )

    if [[ "$use_cache" == "false" ]]; then
        echo "Building from scratch without cache..." >&2
        build_args+=(--no-cache)
    fi

    build_args+=(--tag "$docker_image_name")

    # Pipe the Dockerfile via stdin (`-`) so no build context is sent.
    docker build "${build_args[@]}" - < "$dockerfile_path" >&2
}

generate_container_name() {
    local dir_basename
    dir_basename=$(basename "$current_dir" | tr -cd 'a-zA-Z0-9_.-')
    echo "${container_prefix}_${dir_basename:0:44}_$(shuf -i 1-999999 -n 1)"
}

# Run Claude Code in a Docker container.
# Usage: run_container [--exec] [args...]
# --exec: Use exec to replace current process.
run_container() {
    local use_exec=false

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --exec)
                use_exec=true
                shift
                ;;
            *)
                break
                ;;
        esac
    done

    local cmd=(
        docker run

        # Delete the container when it exits.
        --rm

        # Run an init process that will properly manage signals and other OS
        # facilities.
        --init

        # Container name.
        --name "$(generate_container_name)"

        # So that the agent can reach services running on the host via
        # `host.docker.internal`.
        --add-host "host.docker.internal:host-gateway"

        # Mount current directory and set it as the working directory.
        --volume "$current_dir:$current_dir"
        --workdir "$current_dir"

        # Mount git configuration so my aliases and other preferences are in
        # effect.
        --volume "$HOME/.config/git:$HOME/.config/git:ro"

        # Some binaries that my agents need.
        --volume "$devel_dir/dotfiles/bin/ai_commit:/usr/local/bin/ai_commit:ro"
        --volume "$devel_dir/dotfiles/bin/review_diff:/usr/local/bin/review_diff:ro"

        # Claude Code mounts.
        --volume "$HOME/.claude-$profile:$HOME/.claude"
        --volume "$HOME/.claude-$profile.json:$HOME/.claude.json"

        # Agent of Empires environment variables and mounts.
        --env "AOE_INSTANCE_ID"
        --volume "/tmp/aoe-hooks:/tmp/aoe-hooks"

        # Anthropic's API key if available. If not defined, Claude Code will
        # check for OAuth credentials. If not there too, it will ask the user
        # how they want to login.
        --env ANTHROPIC_API_KEY

        # This is so the agent can use `gh`.
        --env GH_TOKEN

        # This enables sessions to show up with the right timestamps.
        --env "TZ=${TZ:-$(readlink /etc/localtime 2> /dev/null | sed 's|.*/zoneinfo/||')}"

        # This is used to show the active profile in the status line.
        --env "AGENT_PROFILE=$profile"

        # Claude Code uses this to know search for file suggestions on `@`.
        --env RIPGREP_CONFIG_PATH

        # Terminal configuration.
        --env TERM
        --env COLORTERM
        --env FORCE_COLOR
        --env NO_COLOR
    )

    # When processing output or in print mode, don't allocate a TTY or attach
    # stdin interactively so we can capture the output cleanly. When stdin is
    # not a TTY, also skip both flags.
    if [[ "$process_output" != "true" ]] \
        && [[ "$harness_print_mode" != "true" ]] \
        && [ -t 0 ]; then
        cmd+=(--interactive --tty)
    fi

    # If this is not the main Git worktree, also mount the main worktree.
    if [ -f "$current_dir/.git" ]; then
        # .git is a file, not a directory - this is not the main worktree.
        main_worktree=$(
            git worktree list --porcelain \
                | grep -m1 "^worktree " | sed 's/^worktree //'
        )
        main_worktree_realpath=$(realpath "$main_worktree")

        if [[ "$main_worktree_realpath/" != "$devel_dir/"* ]]; then
            echo "Error: Main worktree must be in ~/devel" >&2
            exit 1
        fi

        cmd+=(--volume "$main_worktree_realpath:$main_worktree_realpath")
    fi

    # Mount `dotfiles` so symlinks work.
    if [ "$current_dir" != "$devel_dir/dotfiles" ]; then
        cmd+=(--volume "$devel_dir/dotfiles:$devel_dir/dotfiles:ro")
    fi
    # Mount `dotfiles-secret` so symlinks work.
    if [ "$current_dir" != "$devel_dir/dotfiles-secret" ]; then
        cmd+=(
            --volume "$devel_dir/dotfiles-secret:$devel_dir/dotfiles-secret:ro"
        )
    fi

    # Mount additional projects from `AGENTS_ADDITIONAL_PROJECTS`.
    if [ -n "${AGENTS_ADDITIONAL_PROJECTS:-}" ]; then
        IFS=':' read -ra ADDITIONAL_PROJECTS <<< "$AGENTS_ADDITIONAL_PROJECTS"
        for additional_project in "${ADDITIONAL_PROJECTS[@]}"; do
            # Trim whitespace.
            additional_project=$(sed 's/^[[:space:]]*//;s/[[:space:]]*$//' <<< "$additional_project")
            if [ -n "$additional_project" ]; then
                # Skip if this is the current project to avoid duplicate
                # mounts.
                if [ "$additional_project" == "$project_relative_dir" ]; then
                    echo "Skipping additional mount for current project: $additional_project" >&2
                    continue
                fi
                project_path="$devel_dir/$additional_project"
                if [ -d "$project_path" ]; then
                    echo "Additional mount point: $additional_project" >&2
                    cmd+=(--volume "$project_path:$project_path:ro")
                else
                    echo "Warning: Additional project '$additional_project' does not exist at $project_path" >&2
                fi
            fi
        done
    fi

    # Relay additional environment variables from
    # `AGENTS_ADDITIONAL_ENV_VARS`.
    if [ -n "${AGENTS_ADDITIONAL_ENV_VARS:-}" ]; then
        IFS=':' read -ra ADDITIONAL_ENV_VARS <<< "$AGENTS_ADDITIONAL_ENV_VARS"
        for additional_env_var in "${ADDITIONAL_ENV_VARS[@]}"; do
            # Trim whitespace.
            additional_env_var=$(sed 's/^[[:space:]]*//;s/[[:space:]]*$//' <<< "$additional_env_var")
            if [ -n "$additional_env_var" ]; then
                if [[ ! "$additional_env_var" =~ ^[a-zA-Z_][a-zA-Z0-9_]*$ ]]; then
                    echo "Warning: Skipping invalid env var name: $additional_env_var" >&2
                    continue
                fi
                echo "Additional environment variable: $additional_env_var" >&2
                cmd+=(--env "$additional_env_var")
            fi
        done
    fi

    # Set up Docker access from inside the container.
    if [ -S "$HOME/.docker/run/docker.sock" ]; then
        docker_socket="$HOME/.docker/run/docker.sock"
    elif [ -S "/var/run/docker.sock" ]; then
        docker_socket="/var/run/docker.sock"
    else
        echo "Warning: Docker socket not found, Docker will not be available inside the container" >&2
        docker_socket=""
    fi
    if [ -n "$docker_socket" ]; then
        cmd+=(
            --volume "$docker_socket:/var/run/docker.sock"
            --env "DOCKER_HOST=unix:///var/run/docker.sock"
        )
    fi

    cmd+=(
        # The image we just built.
        "$docker_image_name"

        # Whatever arguments we want to pass to the harness.
        "$@"
    )

    echo "Running container..." >&2

    if [[ "$use_exec" == "true" ]]; then
        exec "${cmd[@]}"
    else
        "${cmd[@]}"
    fi
}

# Function to round cost up to the next cent for display.
round_up_cents() {
    local value=$1
    local rounded
    rounded=$(
        bc << EOF
scale=0
tmp = $value * 100
tmp = tmp / 1
if (tmp < $value * 100) tmp = tmp + 1
scale=2
tmp / 100
EOF
    )
    printf "%.2f" "$rounded"
}

# Function to format duration as XhYmZ.WWWs.
format_duration() {
    local total_seconds=$1

    # Handle zero or empty input.
    if [[ -z "$total_seconds" ]] || [[ $(bc <<< "$total_seconds == 0") -eq 1 ]]; then
        echo "0.000s"
        return
    fi

    local hours
    local remainder
    local minutes
    local seconds

    hours=$(bc <<< "$total_seconds / 3600")
    remainder=$(bc <<< "$total_seconds - ($hours * 3600)")
    minutes=$(bc <<< "$remainder / 60")
    seconds=$(bc <<< "$remainder - ($minutes * 60)")

    local result=""
    if [ "$hours" -gt 0 ]; then
        result="${hours}h"
    fi
    if [ "$minutes" -gt 0 ] || [ "$hours" -gt 0 ]; then
        result="${result}${minutes}m"
    fi
    result="${result}$(printf "%.3f" "$seconds")s"
    echo "$result"
}

# ============================================================================
# Main Execution
# ============================================================================

if [ -z "$profile" ]; then
    component_count=$(tr '/' '\n' <<< "$project_relative_dir" | wc -l)
    if [ "$component_count" -gt 1 ]; then
        profile="$(cut -d'/' -f1 <<< "$project_relative_dir")"
    else
        profile="$username"
    fi
fi

echo "Profile '$profile'..." >&2

# Validate profile name to prevent command injection.
# Max length: 64 characters, alphanumeric with dots, dashes, underscores.
if [[ ! "$profile" =~ ^[a-zA-Z0-9_]([a-zA-Z0-9._-]{0,62}[a-zA-Z0-9_])?$ ]]; then
    echo "Error: Invalid profile name '$profile'" >&2
    exit 1
fi

# Fetch API key and GitHub token from 1Password if not already provided.
if [[ "${AGENT_ENV_SET:-}" != "true" ]]; then
    # Fetch API key from 1Password if not already set.
    if [ -z "${ANTHROPIC_API_KEY:-}" ]; then
        echo -n "Fetching AI Agents configuration from 1Password..." >&2
        if ! SECRETS=$(op read "op://Private/AI Agents Configuration/notesPlain" 2>&1); then
            echo "Error: Failed to retrieve configuration from 1Password" >&2
            echo "Make sure you are logged in to 1Password CLI (run: op signin)" >&2
            exit 1
        fi
        echo " done!" >&2

        # Validate that we got valid JSON.
        if ! jq empty <<< "$SECRETS" 2> /dev/null; then
            echo "Error: Retrieved secret is not valid JSON" >&2
            exit 1
        fi

        # Check if fallback to username profile is allowed.
        fallback_to_username=$(jq -r --arg p "$profile" \
            '.profiles[$p].fallback_to_username // false' \
            <<< "$SECRETS")

        # Extract API key, falling back to the username profile only if the
        # profile allows it via `fallback_to_username`.
        if [[ "$fallback_to_username" == "true" ]]; then
            ANTHROPIC_API_KEY=$(jq -r --arg p "$profile" --arg u "$username" \
                '(.profiles[$p].api_key // .profiles[$u].api_key) // empty' \
                <<< "$SECRETS")
        else
            ANTHROPIC_API_KEY=$(jq -r --arg p "$profile" \
                '.profiles[$p].api_key // empty' \
                <<< "$SECRETS")
        fi

        if [[ -z "$ANTHROPIC_API_KEY" || "$ANTHROPIC_API_KEY" == "null" ]]; then
            echo "Warning: No API key found for profile '$profile'" >&2
        else
            export ANTHROPIC_API_KEY
        fi
    fi

    # Fetch GitHub token from 1Password if not already set.
    if [ -z "${GH_TOKEN:-}" ]; then
        echo -n "Fetching GitHub token from 1Password..." >&2
        if ! GH_TOKEN=$(op read "op://Private/GH Token/notesPlain" 2>&1); then
            echo "Error: Failed to retrieve GH_TOKEN from 1Password" >&2
            echo "Make sure you are logged in to 1Password CLI (run: op signin)" >&2
            exit 1
        fi
        echo " done!" >&2

        if [[ -z "$GH_TOKEN" ]]; then
            echo "Error: GH_TOKEN is empty" >&2
            exit 1
        fi

        export GH_TOKEN
    fi
fi

if [[ "$env_only" == "true" ]]; then
    # Output shell commands to be eval'd for environment variable export.
    [ -n "${ANTHROPIC_API_KEY:-}" ] \
        && printf "export ANTHROPIC_API_KEY=%q\n" "$ANTHROPIC_API_KEY"
    [ -n "${GH_TOKEN:-}" ] && printf "export GH_TOKEN=%q\n" "$GH_TOKEN"
    echo "export AGENT_ENV_SET=true"
    echo "Environment variables exported for profile '$profile'" >&2
    exit 0
fi

today=$(date +%Y-%m-%d)

# Get last build date from the Docker image metadata (empty if image doesn't
# exist).
last_build_date=$(
    docker image inspect "$docker_image_name" \
        --format '{{.Metadata.LastTagTime.Format "2006-01-02"}}' \
        2> /dev/null \
        || true
)

# Get the image's creation timestamp (seconds since epoch, empty if image
# doesn't exist).
last_build_timestamp=$(
    docker image inspect "$docker_image_name" \
        --format '{{.Metadata.LastTagTime.Unix}}' \
        2> /dev/null \
        || true
)

# Get the Dockerfile's modification time (seconds since epoch).
dockerfile_mtime=$(
    stat -c %Y "$dockerfile_path" 2> /dev/null \
        || stat -f %m "$dockerfile_path" 2> /dev/null \
        || echo "0"
)

needs_rebuild=false
if [[ "$no_build_cache" == "true" ]]; then
    needs_rebuild=true
elif [[ "$force_rebuild" == "true" ]]; then
    needs_rebuild=true
elif [[ "$last_build_date" != "$today" ]]; then
    needs_rebuild=true
elif [[ -n "$last_build_timestamp" ]] \
    && [[ "$dockerfile_mtime" -gt "$last_build_timestamp" ]]; then
    needs_rebuild=true
elif [[ -z "$last_build_date" ]]; then
    # Image doesn't exist at all.
    needs_rebuild=true
fi

if [[ "$no_rebuild" == "true" ]]; then
    # Skip rebuild entirely - verify image exists.
    if [[ -z "$last_build_date" ]]; then
        echo "Error: Docker image does not exist and --no-rebuild was specified" >&2
        exit 1
    fi
    echo "Skipping rebuild (--no-rebuild specified)" >&2
elif [[ "$needs_rebuild" == "true" ]]; then
    use_cache="true"
    if [[ "$no_build_cache" == "true" ]]; then
        use_cache="false"
    fi
    if ! build_image "$use_cache"; then
        if [[ "$allow_stale" == "true" ]]; then
            if [[ -z "$last_build_date" ]]; then
                echo "Error: Docker build failed and no existing image found" >&2
                exit 1
            fi
            echo "Build failed, using existing image (--allow-stale)" >&2
        else
            echo "Error: Docker build failed" >&2
            exit 1
        fi
    fi
fi

mkdir -p "$HOME/.claude-$profile"
cp -a "$HOME/.claude-origin/." "$HOME/.claude-$profile"
# Make `~/claude-$profile/settings.json` a hard copy, not a symlink.
dereference "$HOME/.claude-$profile/settings.json"
[ -f "$HOME/.claude-$profile.json" ] \
    || echo "{}" > "$HOME/.claude-$profile.json"

if [[ "$process_output" == "true" ]]; then
    # Capture output and process it.
    output=$(run_container "${harness_args[@]}")
    process_print_output "$output"
else
    # Pass all arguments directly to Claude Code.
    run_container --exec "${harness_args[@]}"
fi

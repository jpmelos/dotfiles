#!/usr/bin/env bash
set -euo pipefail
trap 'echo "Exit status $? at line $LINENO from: $BASH_COMMAND" >&2' ERR

get_diff() {
    diff=$(git diff)
    git_command="git diff"
    if [ -n "$diff" ]; then
        return 0
    fi

    diff=$(git diff --cached)
    git_command="git diff --cached"
    if [ -n "$diff" ]; then
        return 0
    fi

    main_branch=$(git main-branch)

    diff=$(git diff "$main_branch...")
    git_command="git diff $main_branch..."
    if [ -n "$diff" ]; then
        commits=$(git log "$main_branch..." --oneline)
        return 0
    fi

    echo "There is nothing to review."
    return 1
}

get_diff || exit 1

if [ -n "${commits:-}" ]; then
    cat << EOF
The commits since $main_branch were obtained using:

\`\`\`
git log $main_branch... --oneline
\`\`\`

=================

$commits

=================

EOF
fi

cat << EOF
The changes were obtained using:

\`\`\`
$git_command
\`\`\`

=================

$diff

=================
EOF
